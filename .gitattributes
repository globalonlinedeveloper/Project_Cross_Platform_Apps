# Normalize line endings so genuine corruption stands out instead of drowning in
# CRLF-vs-LF noise (Windows host + Linux CI + sandbox clones all agree on LF).
* text=auto eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.ttf binary
*.otf binary

# git-crypt: encrypt private strategy docs (-text exempts them from global eol=lf so ciphertext round-trips byte-exact)
NIKATRU_MASTER_REQUIREMENTS.md filter=git-crypt diff=git-crypt -text
PROJECT_STATE.md filter=git-crypt diff=git-crypt -text
