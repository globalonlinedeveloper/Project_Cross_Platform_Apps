# ─────────────────────────────────────────────────────────────
# SECRETS — never commit. All credentials live in .cowork-private/
# ─────────────────────────────────────────────────────────────
.cowork-private/
*.env
!*.env.example
.dev.vars
!.dev.vars.example
*.pem
*.key
*-service-account*.json
secrets.*

# ── App live config (dart-define-from-file; non-secret but env-specific) ──
apps/subly/config/*.json
!apps/subly/config/*.example.json

# ── Flutter / Dart (GLOBAL — survives app/→apps/ move) ──
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/build/
**/.packages
**/pubspec.lock
**/ios/Pods/
**/android/.gradle/
**/android/local.properties
**/*/GeneratedPluginRegistrant.*
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/
**/macos/Flutter/ephemeral/

# ── Node / Cloudflare / web (GLOBAL) ──
**/node_modules/
**/.wrangler/
**/dist/
**/_site/
coverage/

# ── COMMITTED generated design tokens (Style Dictionary outputs) — re-include ──
!/packages/tokens/build/
!/packages/tokens/build/**

# ── Pub workspace root artifacts ──
/.dart_tool/
/pubspec.lock

# ── IDE / Melos ──
/.idea/
*.iml
.vscode/

# ── OS / editor ──
.DS_Store
Thumbs.db
*.log

# ── Internal planning docs (kept OUT of the public repo) ──
/Backend Research - Firebase vs Cloudflare (July 2026).md
/Subscription tracker app design/
/NIKATRU_GAP_ANALYSIS*.md

# ── strategy docs -> private nikatru-company repo ──
/PROJECT_STATE.md
/NIKATRU_MASTER_REQUIREMENTS.md
